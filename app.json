{
  "expo": {
    "name": "KJ Fitness",
    "slug": "kj-fitness-app",
    "version": "1.0.0",
    "scheme": "kjfitness",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pappostudios.kjfitness"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A1A"
      },
      "package": "com.pappostudios.kjfitness"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "intentFilters": [
              {
                "action": "VIEW",
                "autoVerify": true,
                "data": [
                  {
                    "scheme": "com.googleusercontent.apps.525333297888-s6qfi53grleplf0tbdh1gvddhh4jr3q3",
                    "host": "oauth2redirect"
                  }
                ],
                "category": [
                  "BROWSABLE",
                  "DEFAULT"
                ]
              }
            ]
          }
        }
      ],
      "expo-font"
    ],
    "updates": {
      "url": "https://u.expo.dev/53c02adf-30fb-45b4-970d-ef07931554ae"
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "extra": {
      "eas": {
        "projectId": "53c02adf-30fb-45b4-970d-ef07931554ae"
      }
    }
  }
}
